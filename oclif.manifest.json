{
  "commands": {
    "exec": {
      "aliases": [],
      "args": {},
      "description": "Execute code against a notebook in a single call (auto-opens and reuses channels)",
      "examples": [
        "$ jupyter-link exec --url http://host:8888/notebooks/foo.ipynb?token=XYZ --code-file /tmp/x.py",
        "$ jupyter-link exec --notebook foo.ipynb --code \"print(1+1)\""
      ],
      "flags": {
        "url": {
          "description": "Full Jupyter URL (may include ?token=… and /notebooks/<path>)",
          "name": "url",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "notebook": {
          "char": "n",
          "description": "Notebook path (server-relative, POSIX-style)",
          "name": "notebook",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "code": {
          "description": "Code literal. Use '-' to read raw stdin.",
          "name": "code",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "code-file": {
          "description": "Path to a file whose contents are the code",
          "name": "code-file",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "index": {
          "description": "Cell index (0-based)",
          "name": "index",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "position": {
          "description": "Insert position when index is omitted",
          "name": "position",
          "default": "end",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "start",
            "end"
          ],
          "type": "option"
        },
        "timeout": {
          "description": "Timeout in seconds",
          "name": "timeout",
          "default": 60,
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
